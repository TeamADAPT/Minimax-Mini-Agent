[Unit]
Description=Testova visible TUI NATS bridge
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/adapt/platform/novaops/controlplane/pipecat-voice
EnvironmentFile=-/adapt/secrets/db.env
EnvironmentFile=-/adapt/secrets/m2.env
Environment=DISPLAY=:0
Environment=ECHO_TUI_AGENT=testova
Environment="ECHO_TUI_WINDOW_NAME=Testova CLI"
Environment=ECHO_PROFILE_ROOT=/home/x/.hermes/profiles/testova
Environment=ECHO_TUI_ALLOW_CLI_FALLBACK=0
Environment=ECHO_TUI_DELIVERY_TIMEOUT=90
Environment=ECHO_TUI_REPLY_CAPTURE_TIMEOUT=300
ExecStart=/usr/bin/python3 /adapt/platform/novaops/controlplane/pipecat-voice/scripts/echo_tui_nats_bridge.py
Restart=on-failure
RestartSec=3

[Install]
WantedBy=default.target
